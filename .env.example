# Entorno general de ejecucion.
APP_NAME=automatizador-notas-voz
APP_ENV=development
DEBUG=true

# Configuracion de Docker.
DOCKER_PROJECT_NAME=automatizador-notas-voz
DOCKER_CONTAINER_NAME=automatizador-notas-voz
DOCKER_RESTART_POLICY=unless-stopped
DOCKER_WORKDIR=/app
DOCKER_APP_USER=appuser
DOCKER_APP_GROUP=appuser
DOCKER_USE_BIND_MOUNTS=true

# Rutas base que la aplicacion debe usar dentro del contenedor o en local.
DATABASE_DIR=./database
LOG_DIR=./logs
AUDIO_DIR=./audios
TIMEZONE=UTC

# Logging.
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)s | %(name)s | %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
LOG_FILE=./logs/app.log
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_ROTATE_MAX_BYTES=5242880
LOG_ROTATE_BACKUP_COUNT=5

# SQLite.
DATABASE_PATH=./database/app.db
SQLITE_TIMEOUT_SECONDS=30
SQLITE_JOURNAL_MODE=WAL
SQLITE_FOREIGN_KEYS=true
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_BACKUP_ENABLED=false
SQLITE_BACKUP_DIR=./database/backups

# Groq.
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=60
GROQ_MAX_RETRIES=3
GROQ_TEMPERATURE=0
GROQ_LANGUAGE=es

# Telegram.
BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLLING_TIMEOUT_SECONDS=20
TELEGRAM_WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_MAX_MESSAGE_LENGTH=4096

# Limpieza automatica.
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_SECONDS=3600
CLEANUP_MAX_AUDIO_AGE_HOURS=24
CLEANUP_MAX_LOG_AGE_DAYS=7
CLEANUP_MAX_TEMP_AGE_HOURS=12
CLEANUP_DRY_RUN=false