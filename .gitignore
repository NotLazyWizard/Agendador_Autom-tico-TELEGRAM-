# Ignora el archivo de entorno real porque suele contener secretos.
.env

# Ignora artefactos de Python generados automaticamente.
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignora directorios de entornos virtuales locales.
.venv/
venv/
env/

# Ignora caches de herramientas de calidad y test.
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Ignora datos locales persistentes que se almacenan fuera del control de version.
database/
logs/
audios/

# Ignora archivos temporales del sistema y del editor.
.DS_Store
Thumbs.db
.vscode/
.idea/